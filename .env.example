# Dashboard Weather - Configuration
# Copy this file to .env and adjust values as needed
# cp .env.example .env

# Server settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Location settings (default: Trier, Germany)
DASHBOARD_LOCATION=Trier, Germany
DASHBOARD_LATITUDE=49.7596
DASHBOARD_LONGITUDE=6.6442
DASHBOARD_TIMEZONE=Europe/Berlin

# Cache TTL in seconds (default: 300 = 5 minutes)
DASHBOARD_CACHE_TTL=300

# HiOrg-Server API (optional - leave empty to disable)
# HIORG_API_URL=https://hiorg-server.de/api
